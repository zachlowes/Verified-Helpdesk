{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<your-tenant-id>",
    "ClientId": "<your-app-registration-client-id>",
    "CallbackPath": "/signin-oidc"
  },

  "AppSettings": {
    "CookieKey": "state",
    "CookieExpiresInSeconds": 7200,
    "CacheExpiresInSeconds": 300,
    "CompanyName": "Your Organization",
    "CompanyLogo": "",
    "PortalTitle": "Verified Helpdesk",
    "AuthorizedAgentLabel": "Authorized Helpdesk Agent",
    "ITHelpdeskGroupId": "<your-it-helpdesk-group-object-id>",
    "UseTeamsWebhook": false,
    "TeamsWebhookURL": ""
  },

  "VerifiedID": {
    "ApiEndpoint": "https://verifiedid.did.msidentity.com/v1.0/verifiableCredentials/",
    "TenantId": "<your-tenant-id>",
    "Authority": "https://login.microsoftonline.com/",
    "scope": "3db474b9-6a0c-4840-96ac-1fceb342124f/.default",
    "ManagedIdentity": true,
    "ClientId": "",
    "ClientSecret": "",
    "CertificateName": "",
    "DidAuthority": "<your-issuer-did>",
    "client_name": "Helpdesk Verification",
    "Purpose": "To prove your identity",
    "includeQRCode": false,
    "includeReceipt": true,
    "allowRevoked": false,
    "validateLinkedDomain": true,
    "EnableFaceCheck": false,
    "CredentialType": "VerifiedEmployee",
    "UpnClaimName": "revocationId",
    "EmailClaimName": "mail",
    "DisplayNameClaimName": "displayName",
    "sourcePhotoClaimName": "photo",
    "matchConfidenceThreshold": 70
  }
}
